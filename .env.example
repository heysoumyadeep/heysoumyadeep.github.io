# Premium Blog Configuration
# Comma-separated list of valid 8-digit unlock codes
# Example: 12345678,87654321,11223344
# In production, set these as GitHub Actions secrets
VITE_PREMIUM_CODES=12345678

# Encryption key for localStorage (keep this secret and unique)
VITE_ENCRYPTION_KEY=your_unique_encryption_key_here

# ── EmailJS (Contact Form) ────────────────────────────────────────────────────
# Used by ContactForm.jsx to send a thank-you email to the visitor.
# Sign up at https://www.emailjs.com and create a service + template.
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
